      "MAC",
      "WINDOWS"
    ],
    "lifecycle": [
      "OPERATIONS",
      "POST-BUILD"
    ],
    "supportedStandards": [
      "CYCLONEDX",
      "CPE",
      "PACKAGE_URL"
    ],
    "cycloneDxVersion": [
      "CYCLONEDX_V1.6"
    ],
    "supportedLanguages": [
      "C/C++"
    ]
  }
