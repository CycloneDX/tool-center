{
  "$schema": "https://cyclonedx.org/schema/tool-center-v2.tool.schema.json",
  "specVersion": "2.0",
  "tool": {
    "name": "Vulnetix CLI",
    "publisher": "Vulnetix",
    "description": "A vulnerability scanner for CBOM, AIBOM, SAST, IaC, container images, malware IOCs, and SCA/licenses of software ecosystems. Works with most well-known package manager manifests and supports CycloneDX for xBOM and VEX, SPDX Licenses, and OpenVEX.",
    "repository_url": "https://github.com/Vulnetix/cli",
    "website_url": "https://www.vulnetix.com/features/code-scanner",
    "capabilities": [
      "SBOM",
      "VDR/VEX",
      "AI/ML-BOM",
      "CBOM"
    ],
    "availability": [
      "OPEN_SOURCE",
      "OSI_APPROVED"
    ],
    "functions": [
      "ANALYSIS",
      "TRANSFORM",
      "AUTHOR"
    ],
    "analysis": [
      "SECURITY_VULNERABILITIES",
      "POLICY_EVALUATION",
      "LICENSE_REPORTING",
      "OUTDATED_COMPONENTS"
    ],
    "transform": [
      "BOM_STANDARD",
      "BOM_SERIALIZATION_FORMAT",
      "BOM_VERSION"
    ],
    "packaging": [
      "COMMAND_LINE_UTILITY",
      "GITHUB_ACTION",
      "GITLAB_CI_TEMPLATE"
    ],
    "library": [
      "GO"
    ],
    "platform": [
      "LINUX",
      "MAC",
      "WINDOWS"
    ],
    "lifecycle": [
      "PRE-BUILD",
      "BUILD",
      "POST-BUILD",
      "OPERATIONS",
      "DISCOVERY"
    ],
    "supportedStandards": [
      "CYCLONEDX",
      "SPDX",
      "PACKAGE_URL",
      "CPE"
    ],
    "cycloneDxVersion": [
      "CYCLONEDX_V1.4",
      "CYCLONEDX_V1.5",
      "CYCLONEDX_V1.6",
      "CYCLONEDX_V1.7"
    ],
    "supportedLanguages": [
      "C/C++",
      ".NET",
      "ERLANG_ELIXIR",
      "GO",
      "GROOVY",
      "JAVA",
      "JAVASCRIPT/TYPESCRIPT",
      "KOTLIN",
      "NODE.JS",
      "PHP",
      "PYTHON",
      "RUBY",
      "RUST",
      "SCALA",
      "SWIFT"
    ]
  }
}
